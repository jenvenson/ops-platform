# ============================================================
# OPS Platform 环境变量配置
# ============================================================
# 复制此文件为 .env 并修改：cp .env.example .env
# 标记为 (必需) 的变量必须填写，其他可用默认值
# ============================================================

# ---- 数据库 (必需) ----
DB_PASSWORD=your_secure_mysql_password
# DB_HOST=mysql
# DB_PORT=3306
# DB_USER=root
# DB_NAME=ops_platform

# ---- Redis (必需) ----
REDIS_PASSWORD=your_secure_redis_password
# REDIS_HOST=redis
# REDIS_PORT=6379

# ---- JWT (必需) ----
JWT_SECRET=your_jwt_secret_key_change_in_production

# ---- Jenkins (可选) ----
# JENKINS_URL=http://your-jenkins-server:8080
# JENKINS_USERNAME=admin
# JENKINS_TOKEN=your_jenkins_api_token
# JENKINS_TIMEOUT=30

# ---- Grafana (可选) ----
# GRAFANA_URL=http://your-grafana-host:3000
# GRAFANA_USERNAME=admin
# GRAFANA_PASSWORD=your_grafana_password
# GRAFANA_UPSTREAM=http://your-grafana-host:3000/
# GRAFANA_HOST_HEADER=your-grafana-host:3000
# GRAFANA_BASIC_AUTH=           # 如需 Basic Auth，填写 base64(admin:password)
# GRAFANA_APP_URL=http://localhost:3000/

# ---- AI 运维小助手 (可选) ----
# ASSISTANT_ENABLED=false
# ASSISTANT_PROVIDER=ollama
# OLLAMA_BASE_URL=http://docker-host:11434
# OLLAMA_CHAT_MODEL=qwen3:8b
# OLLAMA_EMBED_MODEL=qwen3-embedding:4b
# ASSISTANT_REQUEST_TIMEOUT_SEC=60
# ASSISTANT_RATE_LIMIT_PER_MINUTE=20
# ASSISTANT_MAX_MESSAGE_RUNES=4096
# 第三方模型 (替换上面的 ollama 配置):
# ASSISTANT_API_KEY=sk-your-api-key
# ASSISTANT_BASE_URL=https://your-model-api.example.com/v1
# ASSISTANT_CHAT_MODEL=your-model-name
# ASSISTANT_EMBED_MODEL=your-embed-model

# ---- 安全扫描 (可选) ----
# OPS_NMAP_PROFILE=dev
# OPS_BROWSER_DISCOVERY_URL=http://ops-browser-helper:31730/discover
# NUCLEI_VERSION=v3.6.2
# NUCLEI_BINARY_URL=https://github.com/projectdiscovery/nuclei/releases/download/v3.6.2/nuclei_3.6.2_linux_amd64.zip

# ---- FIM 文件完整性监控 (可选) ----
# FIM_SSH_USER=
# FIM_SSH_PASSWORD=
# FIM_SSH_PRIVATE_KEY=
# FIM_SSH_PRIVATE_KEY_PATH=
# FIM_SSH_TIMEOUT_SEC=15

# ---- 生产环境容器命名 (可选，避免多实例冲突) ----
# MYSQL_CONTAINER_NAME=ops-mysql
# REDIS_CONTAINER_NAME=ops-redis
# BACKEND_CONTAINER_NAME=ops-backend
# NGINX_CONTAINER_NAME=ops-nginx
# MYSQL_PORT=3306
# REDIS_PORT_PUBLISHED=6379
# BACKEND_PORT=8080
# NGINX_PORT=80

# ---- Go 模块代理 (可选，国内用户可设 https://goproxy.cn,direct) ----
# GOPROXY=
