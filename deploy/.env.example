# 数据库密码（必需）
DB_PASSWORD=your_secure_mysql_password

# Redis 密码（可选，默认：default_redis_password）
REDIS_PASSWORD=your_secure_redis_password

# JWT Secret（必需）
JWT_SECRET=your_jwt_secret_key_change_in_production

# Grafana / 监控代理（建议生产显式配置）
GRAFANA_URL=http://grafana.internal:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=your_grafana_password
GRAFANA_UPSTREAM=http://grafana.internal:3000/
GRAFANA_HOST_HEADER=grafana.internal:3000
# 如需 Basic Auth，可填 base64(admin:password)；不需要则留空
GRAFANA_BASIC_AUTH=
GRAFANA_APP_URL=http://grafana.internal:3000/

# 运维小助手（开发环境默认使用宿主机 Ollama）
ASSISTANT_PROVIDER=ollama
OLLAMA_BASE_URL=http://docker-host:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
