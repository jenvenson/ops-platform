# Dev base image — pre-installs all slow scan tools so container restarts are fast.
# Build once with: docker build -f deploy/Dockerfile.backend-dev-base -t ops-backend-dev-base .
# Rebuild only when tool versions or apk packages change.
FROM golang:1.25-alpine

# Use Chinese mirror for reliable apk access
RUN sed -i 's|https://dl-cdn.alpinelinux.org|https://mirrors.aliyun.com|g' /etc/apk/repositories

RUN apk add --no-cache \
    bash \
    nmap \
    nmap-nselibs \
    nmap-scripts \
    unzip \
    curl \
    wget \
    libc6-compat \
    mariadb-client \
    ca-certificates \
    tzdata

# Install nuclei via go install (most reliable method in China)
ARG NUCLEI_VERSION=v3.6.2
ARG GOPROXY=https://goproxy.cn,direct
RUN GOPROXY=${GOPROXY} go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@${NUCLEI_VERSION} && \
    mv /go/bin/nuclei /usr/local/bin/nuclei && \
    nuclei -version 2>&1 | head -1

# Install RustScan (optional — skip if download fails)
RUN cd /tmp && \
    curl -fL --retry 2 --max-time 30 -O \
      https://github.com/bee-san/RustScan/releases/download/2.4.1/x86_64-linux-rustscan.tar.gz.zip && \
    unzip -o x86_64-linux-rustscan.tar.gz.zip && \
    tar xzf x86_64-linux-rustscan.tar.gz && \
    mv rustscan /usr/local/bin/ && \
    chmod +x /usr/local/bin/rustscan && \
    rm -rf /tmp/x86_64-* || echo "RustScan install skipped (download failed)"

# Marker: tells start.sh all tools are pre-installed, skip runtime installs
RUN touch /opt/.dev-base-image
